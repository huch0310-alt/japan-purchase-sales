# 测试环境配置示例
# 复制此文件为 .env.test 并根据实际情况修改

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=japan_purchase_sales_test

# JWT配置
JWT_SECRET=test-jwt-secret-key-for-e2e-testing
JWT_EXPIRES_IN=30d

# 应用配置
NODE_ENV=test
PORT=3001
API_PREFIX=api

# Cookie配置
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
AUTH_COOKIE_MAX_AGE_MS=2592000000

# 文件上传配置
UPLOAD_DIR=./uploads/test
MAX_FILE_SIZE=5242880

# 日志配置
LOG_LEVEL=error

# 其他配置
CORS_ORIGIN=http://localhost:8080
